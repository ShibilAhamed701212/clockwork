    def test_load_fails_incompatible_version(self, tmp_path):
        src = tmp_path / "source"
        src.mkdir()
        pkg = self._pack_and_get_path(src)

        import io, tempfile, shutil
        patched = tmp_path / "patched.clockwork"

        with zipfile.ZipFile(pkg, "r") as zin:
            items = [(item, zin.read(item.filename)) for item in zin.infolist()]

        with zipfile.ZipFile(patched, "w") as zout:
            for item, data in items:
                if item.filename == "metadata.json":
                    meta = json.loads(data)
                    meta["clockwork_version"] = "99.0"
                    meta["package_version"] = 999
                    data = json.dumps(meta).encode()
                if item.filename != "package_checksum.txt":
                    zout.writestr(item, data)

        from clockwork.packaging.checksum import compute_directory_checksum
        with tempfile.TemporaryDirectory() as td:
            zipfile.ZipFile(patched).extractall(td)
            new_checksum = compute_directory_checksum(Path(td))

        with zipfile.ZipFile(patched, "a") as zf:
            zf.writestr("package_checksum.txt", new_checksum)

        loader = PackageLoader(src)
        with pytest.raises(PackagingError, match="[Ii]ncompat"):
            loader.load(patched)
